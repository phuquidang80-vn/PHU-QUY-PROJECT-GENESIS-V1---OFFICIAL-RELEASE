-- HÀM DỊCH CHUYỂN
function Teleport(target)
    pcall(function()
        local root = lp.Character.HumanoidRootPart
        local found = false
        local targets = (target == "Base") and {"Your Plot", "Plot", lp.Name.."'s Plot", "SpawnLocation"} or {target}

        for _, name in pairs(targets) do
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name:lower():find(name:lower()) and (v:IsA("BasePart") or v:IsA("Model")) then
                    root.CFrame = (v:IsA("Model") and v:GetModelCFrame() or v.CFrame) + Vector3.new(0, 8, 0)
                    found = true break
                end
            end
            if found then break end
        end
    end)
end

function CreateBtn(name, color, func)
    local b = Instance.new("TextButton", scroll)
    b.Size = UDim2.new(0, 175, 0, 32)
    b.BackgroundColor3 = color
    b.Text = name
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamSemibold
    b.TextSize = 11
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(func)
    return b
end

-- TÍNH NĂNG CHÍNH
local speedOn, airOn = false, false
local plat = Instance.new("Part")
plat.Size = Vector3.new(25, 1, 25) plat.Anchored = true plat.Transparency = 0.85 plat.Color = Color3.new(0, 1, 1)

local sBtn = CreateBtn("Tốc Độ: TẮT", Color3.fromRGB(45, 45, 45), function() speedOn = not speedOn end)
local aBtn = CreateBtn("Bay Lơ Lửng: TẮT", Color3.fromRGB(45, 45, 45), function() airOn = not airOn end)

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = lp.Character
        sBtn.Text = "Tốc Độ: " .. (speedOn and "BẬT" or "TẮT")
        sBtn.BackgroundColor3 = speedOn and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(45, 45, 45)
        aBtn.Text = "Bay Lơ Lửng: " .. (airOn and "BẬT" or "TẮT")
        aBtn.BackgroundColor3 = airOn and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(45, 45, 45)

        if speedOn then char.Humanoid.WalkSpeed = 100 end
        if airOn then
            plat.Parent = workspace
            plat.CanCollide = true
            local y = plat.Position.Y
            if char.Humanoid.Jump then y = char.HumanoidRootPart.Position.Y - 3.5 end
            plat.CFrame = CFrame.new(char.HumanoidRootPart.Position.X, y, char.HumanoidRootPart.Position.Z)
        else plat.Parent = nil end
    end)
end)

